{
  "name": "n8n-nodes-ers-app",
  "version": "0.1.0",
  "description": "n8n community node for the eResource Scheduler (ERS App) API to manage resources, projects, bookings, requirements, and timehseets in n8n workflows.",
  "license": "MIT",
  "homepage": "https://github.com/lavish-enbraun/ers-n8n#readme",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ers",
    "eResource Scheduler",
    "resource-planning",
    "scheduling",
    "api",
    "integration"
  ],
  "author": {
    "name": "lavish",
    "email": "lavish.pareta@enbraun.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lavish-enbraun/ers-n8n.git"
  },
  "bugs": {
    "url": "https://github.com/lavish-enbraun/ers-n8n/issues"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 2,
    "strict": true,
    "credentials": [
      "dist/credentials/ErsAppOAuth2Api.credentials.js",
      "dist/credentials/ErsAppOAuth2V2OAuth2Api.credentials.js",
      "dist/credentials/ErsAppAccessTokenApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ErsApp/ErsApp.node.js",
      "dist/nodes/ErsApp/ErsAppTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^20.0.0",
    "eslint": "9.32.0",
    "globals": "^16.4.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "^2.7.4"
  }
}
